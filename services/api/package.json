{
  "name": "@fidee/api",
  "version": "0.0.1",
  "private": true,
  "description": "Fidee Lambda microservices",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "aws lambda invoke --function-name fidee-dev-db-migrate --payload \"{}\" --cli-binary-format raw-in-base64-out response.json && type response.json",
    "db:reseed": "aws lambda invoke --function-name fidee-dev-db-migrate --payload eyJhY3Rpb24iOiJyZXNlZWQifQ== response.json && type response.json"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@aws-crypto/sha256-js": "^5.2.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.1060.0",
    "@aws-sdk/client-dynamodb": "^3.1055.0",
    "@aws-sdk/client-s3": "^3.1055.0",
    "@aws-sdk/client-secrets-manager": "^3.1057.0",
    "@aws-sdk/credential-provider-node": "^3.972.55",
    "@aws-sdk/lib-dynamodb": "^3.1055.0",
    "@aws-sdk/protocol-http": "^3.370.0",
    "@aws-sdk/s3-presigned-post": "^3.1055.0",
    "@aws-sdk/signature-v4": "^3.370.0",
    "dotenv": "^17.4.2",
    "pg": "^8.21.0",
    "resend": "^6.12.4"
  }
}
